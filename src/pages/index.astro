---
import AboutMe from "@components/AboutMe.vue";
import Hero from "@components/Hero.vue";
import Nav from "@components/Nav.vue";
import Skills from "@components/Skills.vue";
import Projects from "@components/Projects.vue";
import Timeline from "@components/Timeline.vue";
import Contact from "@components/Contact.vue";
import "@styles/global.css";
import "@styles/font.css";
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SpaceGrotesk-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav client:load />
    <Hero client:idle />
    <main id="main" class="page">
      <section id="about" class="page__section">
        <AboutMe client:idle />
      </section>
      <section id="skills" class="page__section">
        <Skills client:idle />
      </section>
      <section id="projects" class="page__section">
        <Projects client:idle />
      </section>
      <section id="timeline" class="page__section">
        <Timeline client:idle />
      </section>
      <section id="contact" class="page__section">
        <Contact client:idle />
      </section>
    </main>
    <footer class="site-footer">
      <p class="type-meta">© {new Date().getFullYear()} {}.</p>
    </footer>
  </body>
</html>

<style scoped>
  .page {
    max-width: clamp(960px, 90vw, 1280px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .page__section {
    min-height: 100dvh;
    padding: min(12vh, 8rem) clamp(1rem, 4vw, 1.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-height: 500px) and (orientation: landscape) {
    .page__section {
      min-height: auto !important;
      padding: 4rem 1.5rem;
    }
  }

  .skip-link {
    position: absolute;
    top: calc(0.5rem + env(safe-area-inset-top));
    left: calc(0.5rem + env(safe-area-inset-right));
    padding: 0.5rem 1rem;
    color: inherit;
    text-decoration: none;
    transform: translateY(-100%);
    z-index: 2;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-footer {
    max-width: clamp(960px, 90vw, 1280px);
    margin: 0 auto;
    padding: 1.5rem clamp(1rem, 4vw, 1.5rem) 2rem;
    color: var(--muted);
  }
</style>
