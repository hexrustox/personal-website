---
import {
  name,
  role,
  city,
  country,
  description as DESCRIPTION,
} from "../data/meta";

const TITLE = `${name} — ${role}`;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  url: Astro.site,
  jobTitle: role,
  homeLocation: {
    "@type": "Place",
    address: {
      "@type": "PostalAddress",
      addressLocality: city,
      addressCountry: country,
    },
  },
  knowsAbout: [
    "Software Engineering",
    "Web Development",
    "Linux",
    "Developer Tooling",
    "Artificial Intelligence",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name,
  url: Astro.site,
  description: DESCRIPTION,
};

import AboutMe from "@components/AboutMe.vue";
import Hero from "@components/Hero.vue";
import Nav from "@components/Nav.vue";
import Skills from "@components/Skills.vue";
import Projects from "@components/Projects.vue";
import Timeline from "@components/Timeline.vue";
import Contact from "@components/Contact.vue";
import "@styles/global.css";
import "@styles/font.css";
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site} />
    <meta property="og:site_name" content={name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/InterVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/SpaceGrotesk-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav client:idle />
    <Hero client:load />
    <main id="main" class="page" tabindex="-1">
      <section id="about" class="page__section" aria-label="About">
        <AboutMe client:idle />
      </section>
      <section id="skills" class="page__section" aria-label="Skills">
        <Skills client:idle />
      </section>
      <section id="projects" class="page__section" aria-label="Projects">
        <Projects client:idle />
      </section>
      <section id="timeline" class="page__section" aria-label="Timeline">
        <Timeline client:idle />
      </section>
      <section id="contact" class="page__section" aria-label="Contact">
        <Contact client:idle />
      </section>
    </main>
    <footer class="site-footer">
      <p class="type-meta">© {new Date().getFullYear()} {name}.</p>
    </footer>
  </body>
</html>

<style scoped>
  .page {
    max-width: clamp(960px, 90vw, 1280px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .page__section {
    min-height: 100dvh;
    padding: min(12vh, 8rem) clamp(1rem, 4vw, 1.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-height: 500px) and (orientation: landscape) {
    .page__section {
      min-height: auto !important;
      padding: 4rem 1.5rem;
    }
  }

  .skip-link {
    position: absolute;
    top: calc(0.5rem + env(safe-area-inset-top));
    left: calc(0.5rem + env(safe-area-inset-right));
    padding: 0.5rem 1rem;
    color: inherit;
    text-decoration: none;
    transform: translateY(-100%);
    z-index: 2;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-footer {
    max-width: clamp(960px, 90vw, 1280px);
    margin: 0 auto;
    padding: 1.5rem clamp(1rem, 4vw, 1.5rem) 2rem;
    color: var(--muted);
  }
</style>
