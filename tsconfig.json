{
  "extends": ["astro/tsconfigs/base", "@vue/tsconfig/tsconfig.json"],
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"]
    },
    "plugins": [
      { "name": "@astrojs/ts-plugin" },
      { "name": "@vue/typescript-plugin" }
    ],

    "lib": [
      "es2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Error",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
